# =============================================================================
# CMS FWA Detection — Environment Configuration
# Copy this file to .env and fill in values as needed.
# =============================================================================

# --- General ---
CMS_FWA_ENV=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- Data Paths ---
DATA_DIR=data                    # Root data directory (relative to project root)
DUCKDB_PATH=data/cms_fwa.duckdb # DuckDB database file

# --- CMS Data Configuration ---
CMS_DATA_YEAR=2022               # Which year of Part B data to ingest
CMS_DATA_STATE=TX,NM,AZ,NV,OK,CO # Comma-separated state abbreviations (single: TX; multi: TX,NM,AZ)

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Streamlit Dashboard ---
STREAMLIT_PORT=8501

# --- Dagster ---
DAGSTER_HOME=dagster_home
